 function fast(lengths){
        return map(x => x * 0.86, lengths);
    }
    
    
    function convert(notes){
        return map(letter_name_to_midi_note, notes);
    }
    


function make_melody(instrument, note_names, lengths) {
        
        if (is_null(note_names)) {
            return silence_sound(0);
        } 
        else {
            
            const current_note = head(note_names);
            const current_length = head(lengths);
            
            return consecutively(
                list(
                    equal(current_note, "R")
                    ? silence_sound(current_length)
                    : instrument(current_note, current_length),
                    make_melody(instrument, tail(note_names), tail(lengths))
                )
            );
        }
    }





   
